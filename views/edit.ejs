<%- include('partials/header') %>





<main class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card animate-fade-in p-4 p-md-5">
                <div class="text-center mb-5">
                    <h1 class="display-5 fw-bold mb-2">Kelimeyi Düzenle</h1>
                    <p class="text-secondary">Seçili kelimeyi güncelleyerek sözlüğünüzü taze tutun.</p>
                </div>

                <form action="/edit/<%= word.Word_ID %>" method="POST">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label text-secondary mb-2">İngilizce</label>
                            <div class="input-group">
                                <span class="input-group-text bg-transparent border-end-0 text-primary">
                                    <i class="fa-solid fa-font"></i>
                                </span>
                                <input type="text" name="english" class="form-control border-start-0 ps-0" 
                                       value="<%= word.english %>" required>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-secondary mb-2">Türkçe</label>
                            <div class="input-group">
                                <span class="input-group-text bg-transparent border-end-0 text-primary">
                                    <i class="fa-solid fa-language"></i>
                                </span>
                                <input type="text" name="turkish" class="form-control border-start-0 ps-0" 
                                       value="<%= word.turkish %>" required>
                            </div>
                        </div>

                        <div class="col-12 mt-5">
                            <div class="d-flex gap-3">
                                <a href="/delete" class="btn btn-secondary w-100 py-3 rounded-4 bg-opacity-10 border-0">
                                    İptal Et
                                </a>
                                <button type="submit" class="btn btn-primary w-100 py-3 rounded-4 shadow-lg">
                                    <i class="fa-solid fa-save me-2"></i> Güncelle
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>







<%- include('partials/footer') %>
